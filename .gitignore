# Python
__pycache__/
*.pyc
.venv/
**/.mypy_cache/
**/.pytest_cache/
**/.ruff_cache/
.coverage

# IDE
.idea/
.vscode/

# Secrets
.env
.env.local

# OS
.DS_Store

# Pre-commit configs (gerados pelo setup_env.sh na raiz — env/git-dev/ é o fonte)
/pre-commit-config.yaml
/ruff.toml

# Environment — configuração local (cada usuário tem o seu, não commitar)
environment/gateway.md
environment/*.local.md
# Credenciais das organizações (symlabs.env, tecnospeed.env) — .example é commitado
environment/*.env
.claude/settings.json
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock
CLAUDE.md
/*_log.md
*.log

# ft engine — artefatos de runtime (nunca versionar no template)
.serve_url
.context/
artifacts/
runs/
# ``ft/runs`` is source code for the concurrent run lifecycle, not runtime data.
!/ft/runs/
!/ft/runs/**
state/
project/
# Package and tests for repository-level FT workspace management.
!/ft/project/
!/ft/project/**
!/tests/project/
!/tests/project/**
project/state/
project/runs/
project/state/engine_state.yml
project/state/llm_logs/

# Fast Track — processo estatico
# No template: process/ esta commitado (e o fonte)
# No projeto do cliente: ft init adiciona process/ aqui automaticamente

# Reafirma caches gerados depois das exceções de pacotes acima.
**/__pycache__/
*.py[cod]
