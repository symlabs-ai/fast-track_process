# Config da organização Symlabs para o template init `symlabs`.
# Copie para environment/symlabs.env (gitignored) e preencha.
# Secrets: peça ao DevOps — /ask devops (SymVault projeto `devops`).

SYMLABS_GATEWAY_URL=https://symgateway.symlabs.ai
SYMLABS_WORKSPACE_ID=fe49bed1-dccc-41d4-b8cc-fc658e3fa613
SYMLABS_PROVIDER_PATH=anthropic-max

# Admin key do workspace Symlabs [DEV] — registra o projeto e linka a caller.
# Fonte: SymVault devops/FT_ENGINE_GATEWAY_ADMIN_KEY
SYMLABS_ADMIN_KEY=CHANGE_ME

# Caller key do palhano — vai na URL do settings.local.json.
SYMLABS_CALLER_KEY=CHANGE_ME
# Id (uuid) da caller, opcional — só para linkar a caller existente ao projeto.
SYMLABS_CALLER_KEY_ID=
