# Config da organização Tecnospeed para o template init `tecnospeed`.
# Copie para environment/tecnospeed.env (gitignored) e preencha.
#
# ⚠ ORGANIZAÇÃO NÃO PROVISIONADA. Antes de usar, é preciso definir/criar:
#   1. Organization + workspace Tecnospeed [DEV] no SymGateway
#   2. Provider/billing (rotear pela Max pessoal vs credencial da Tecnospeed)
#   3. Git hosting (Gitea org própria vs GitHub/GitLab deles)
#   4. Caller key da org
# Provisionamento é do DevOps/platform_admin — /ask devops.

TECNOSPEED_GATEWAY_URL=https://symgateway.symlabs.ai
TECNOSPEED_WORKSPACE_ID=CHANGE_ME
TECNOSPEED_PROVIDER_PATH=CHANGE_ME

TECNOSPEED_ADMIN_KEY=CHANGE_ME
TECNOSPEED_CALLER_KEY=CHANGE_ME
TECNOSPEED_CALLER_KEY_ID=
